
// ------------------------------------------------

background: {
  rects: [{
    dimensions: [0, 0, "$width", 30]
    fill: {
      start: [0, 0]
      end: [500, 500]
      radial: false
      global: true
      colors: [
        { hsl: ["$hue", "$sat", 20] }
        { hsl: ["$hue", "$sat", 23] }
        { hsl: ["$hue", "$sat", 20] }
        { hsl: ["$hue", "$sat", 17] }
        { hsl: ["$hue", "$sat", 21] }
      ]
    }
  }, {
    dimensions: [0, 30, "$width", "20"]
    fill: { 
      start: [0, 0]
      end: ["$width", 0]
      radial: false
      colors: [
        { hsl: ["$hue", "$sat", 15] }
        { hsl: ["$hue", "$sat", 12] }
        { hsl: ["$hue", "$sat", 13] }
      ]
    }
  }, {
    dimensions: [0, 50, "$width", "$height - 190"]
    fill: [0]
  }, {
    dimensions: [0, "$height - 140", "$width", 100]
    fill: {
      start: [0, 0]
      end: [0, "$height"]
      radial: false
      colors: [
        { hsl: ["$hue", "$sat", 12] }
        { hsl: ["$hue", "$sat", 18] }
        { hsl: ["$hue", "$sat", 15] }
      ]
    }
  }, {
    dimensions: [0, "$height - 40", "$width", "40"]
    fill: {
      start: [0, 0]
      end: ["$width", 0]
      radial: false
      colors: [
        { hsl: ["$hue", "$sat", 19] }
        { hsl: ["$hue", "$sat", 18] }
        { hsl: ["$hue", "$sat", 19] }
      ]
    }
  }, {
    dimensions: [39, 5, 1, 20]
    fill: [211]
  }, {
    dimensions: [179, 5, 1, 20]
    fill: [211]
  }]
}

// ------------------------------------------------

progress-bar: {
  text: $activity: $progress-percent%
  font: $main-font
  text-align: center-right
  text-position: [0, 0]
  text-color: {
    transition: $transition
    value: [255]
    disabled: [255, 0]
  }
  rect: {
    dimensions: [0, 0, "$width * $progress", 2]
    fill: {
      transition: $transition
      value: { hsl: ["$hue", "$sat * 5", 80] }
      disabled:  { hsl: ["$hue", "$sat * 5", 50], a: 0 }
    }
  }
}

// ------------------------------------------------

$popup: {
  font: $main-font
  text-color: [255]
  text-align: center-left
  caret-color: [255]
  selection-color: [200, 200, 255, 100]
  background: {
    background-color: {
      start: [0, 0]
      end: [500, 500]
      radial: false
      global: true
      colors: [
        { hsl: ["$hue", "$sat", 20] }
        { hsl: ["$hue", "$sat", 23] }
        { hsl: ["$hue", "$sat", 20] }
        { hsl: ["$hue", "$sat", 17] }
        { hsl: ["$hue", "$sat", 21] }
      ]
    }
    
    rect: {
      dimensions: [4, 4, "$width - 8", "$height - 8"]
      fill: [0, 50]
    }
  }
}

// ------------------------------------------------

$select-knob: {
  popup: $popup
  font: $main-font
  text: $value
  text-color: [255]
  text-position: [8, 0]
  text-align: center-left
  rect-dimensions: [4, 4, "$width - 8", "$height - 8"]
  rect-fill: [0, 50]
}

selection-start: $select-knob
selection-size: $select-knob

// ------------------------------------------------

show-settings: {
  $icon: images/settings.png
  extends: button.json
}

file-drag: {
  $icon: images/drag-icon.png
  extends: button.json
}

play: {
  $icon: {
    value: images/play-icon.png
    selected: images/pause-icon.png
  }
  extends: button.json
}

rotate-90: {
  $icon: images/rotate-90.png
  extends: button.json
}

rotate-270: {
  $icon: images/rotate-270.png
  extends: button.json
}

flip-horizontal: {
  $icon: images/reverse.png
  extends: button.json
}

flip-vertical: {
  $icon: images/flip.png
  extends: button.json
}

// ------------------------------------------------

spectral-display: {
  color1: [0, 0, 0, 255]
  color2: [60, 60, 179, 120]
  color3: [239, 15 , 0, 200]
  color4: [255, 255, 64]
  color5: [255]
}

waveform-display: {
  stroke: { hsl: ["$hue", "$sat * 5", 60] }
}

scrollbar-waveform-display: {
  stroke: { hsl: ["$hue", "$sat * 5", 60] }
}

// ------------------------------------------------

selection: {
  background: {
    rect-dimensions: ["$select-start", 0, "$select-end - $select-start", 20]
    rect-fill: { hsl: ["$hue", "$sat", 50] }
  }

  $handle: {
    image: $icon
    image-color: { hsl: ["$hue", "$sat", 80] }
    rect-dimensions: [0, 0, 2, "$height"]
    rect-align: top-center
    rect-fill: { hsl: ["$hue", "$sat * 5", 80] }
  }

  start: {
    $icon: images/start-handle.png
    extends: $handle
  }
  
  end: {
    $icon: images/end-handle.png
    extends: $handle
  }
  
  playhead: {
    image: images/playhead.png
    image-color: { hsl: ["$hue", "$sat", 80] }
    image-edges: [9, 9, 10, 2]
  }
}

// ------------------------------------------------

scrollbar: {
  handle: {
    rect-stroke: { hsl: ["$hue", "$sat * 5", 80] }
    rect-fill: { hsl: ["$hue", "$sat", 50], a: 50 }
    rect-stroke-weight: 2
    rect-border-radius: 5
    rect-dimensions: [0, 0, "$width", "$height"]
  }
}

// ------------------------------------------------
