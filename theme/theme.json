
// ------------------------------------------------

theme-name: Default

// ------------------------------------------------

variables: {
  $transition: 200
  $main-font: {
    font: font.ttf
    size: 16
  }

  $hue: 149
  $sat: 10

  $button: {
    image: $icon
    edges: [1, 1, 1, 1]
    image-clip: [0, 0, 772, 772]
    image-position: [0, 0, 20, 20]
    image-align: center
    background-color: {
      transition: $transition
      value: [255, 0]
      hovering: [255, 10]
    }
  }
}

// ------------------------------------------------

font: $main-font

background: {
  background-color: {
    start: [0, 0]
    end: [0, "$height"]
    radial: false
    colors: [
      { hsl: ["$hue", "$sat", 9] }
      { hsl: ["$hue", "$sat", 10] }
    ]
  }
}

// ------------------------------------------------

interface-dimensions: {
  transition: 500
  curve: ease-in-out
  x: 8
  y: 8
  width: $width - 16 - $show-settings * 300
  height: $height - 16
}

settings-dimensions: {
  transition: 500
  curve: ease-in-out
  x: $width - $show-settings * 300
  y: 8
  width: $show-settings * 300
  height: $height - 16
}

// ------------------------------------------------

file: {
  show-settings: {
    $icon: {
      value: settings.png
      selected: close-settings.png
    }
    extends: $button
  }

  background: {
    rects: [{
      dimensions: [0, 0, "$width", 30]
      fill: {
        start: [0, 0]
        end: ["$width", "$height"]
        radial: false
        colors: [
          { hsl: ["$hue", "$sat", 20] }
          { hsl: ["$hue", "$sat", 23] }
          { hsl: ["$hue", "$sat", 20] }
          { hsl: ["$hue", "$sat", 17] }
          { hsl: ["$hue", "$sat", 21] }
        ]
      }
    }, {
      dimensions: [0, 30, "$width", "20"]
      fill: { 
        start: [0, 0]
        end: ["$width", 0]
        radial: false
        colors: [
          { hsl: ["$hue", "$sat", 15] }
          { hsl: ["$hue", "$sat", 12] }
          { hsl: ["$hue", "$sat", 13] }
        ]
      }
    }, {
      dimensions: [0, 50, "$width", "$height - 190"]
      fill: [0]
    }, {
      dimensions: [0, "$height - 140", "$width", 100]
      fill: {
        start: [0, 0]
        end: [0, "$height"]
        radial: false
        colors: [
          { hsl: ["$hue", "$sat", 12] }
          { hsl: ["$hue", "$sat", 18] }
          { hsl: ["$hue", "$sat", 15] }
        ]
      }
    }, {
      dimensions: [0, "$height - 40", "$width", "40"]
      fill: {
        start: [0, 0]
        end: ["$width", 0]
        radial: false
        colors: [
          { hsl: ["$hue", "$sat", 19] }
          { hsl: ["$hue", "$sat", 18] }
          { hsl: ["$hue", "$sat", 19] }
        ]
      }
    }]
  }

  selection-start: {
    font: $main-font
    text: $value
    text-color: [255]
    text-position: [4, 0]
    text-align: center-left
  }

  selection-size: {
    font: $main-font
    text: $value
    text-color: [255]
    text-position: [4, 0]
    text-align: center-left
  }

  file-drag: {
    $icon: drag-icon.png
    extends: $button
  }

  play: {
    $icon: {
      value: play-icon.png
      selected: pause-icon.png
    }
    extends: $button
  }

  rotate-90: {
    $icon: rotate-90.png
    extends: $button
  }

  rotate-270: {
    $icon: rotate-270.png
    extends: $button
  }

  flip-horizontal: {
    $icon: reverse.png
    extends: $button
  }

  flip-vertical: {
    $icon: flip.png
    extends: $button
  }

  spectral-display: {
    color1: [0, 0, 0, 255]
    color2: [60, 60, 179, 120]
    color3: [239, 15 , 0, 200]
    color4: [255, 255, 64]
    color5: [255]
  }

  waveform-display: {
    stroke: { hsl: ["$hue", "$sat * 5", 60] }
  }

  scrollbar-waveform-display: {
    stroke: { hsl: ["$hue", "$sat * 5", 60] }
  }

  selection: {
    background: {
      rects: [{
        x: $select-start
        y: 20
        width: $select-end - $select-start
        height: $height - 20
        fill: { hsl: ["$hue", "$sat", 50], a: 50 }
      }, {
        x: $select-start
        y: 0
        width: $select-end - $select-start
        height: 20
        fill: { hsl: ["$hue", "$sat", 50] }
      }]
    }

    $handle: {
      image: $icon
      image-color: { hsl: ["$hue", "$sat", 80] }
      layers: {
        line: {
          rect: {
            dimensions: [0, 0, 2, "$height"]
            align: top-center
            fill: { hsl: ["$hue", "$sat * 5", 80] }
          }
        }
      }
    }

    start: {
      $icon: start-handle.png
      extends: $handle
    }
    
    end: {
      $icon: end-handle.png
      extends: $handle
    }
    
    playhead: {
      image: playhead.png
      image-color: { hsl: ["$hue", "$sat", 80] }
      image-edges: [9, 9, 10, 2]
    }
  }

  scrollbar: {
    handle: {
      rect: {
        stroke: { hsl: ["$hue", "$sat * 5", 80] }
        fill: { hsl: ["$hue", "$sat", 50], a: 50 }
        stroke-weight: 2
        border-radius: 5
        dimensions: [0, 0, "$width", "$height"]
      }
    }
  }
}

settings: {
  background: {}
  $setting: {
    font: $main-font
    text-align: top-left
    text-color: [255]

    texts: [{
      position: [124, 0]
      text: $value
    }, {
      position: [4, 0]
      text: $name
    }]
  }

  fft-size: $setting
  fft-resolution: $setting
  fft-block-size: $setting
  fft-range: $setting
  generation-directory: {
    font: $main-font
    text-align: top-left
    text-color: [255]
    
    texts: [{
      position: [124, 0]
      text-overflow: dots
      text: $text
    }, {
      position: [4, 0]
      text: Output Folder
    }]
  }
}

// ------------------------------------------------
