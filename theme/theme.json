
// ------------------------------------------------

theme-name: Default

// ------------------------------------------------

variables: {
  $transition: 80
  $main-font: {
    font: font.ttf
    size: 16
  }

  $hue: 200
  $sat: 15
}

// ------------------------------------------------

background: {
  background-color: {
    start: [0, 0]
    end: [0, "$height"]
    radial: false
    colors: [
      { hsl: ["$hue", "$sat", 9] }
      { hsl: ["$hue", "$sat", 10] }
    ]
  }
}

// ------------------------------------------------

interface-dimensions: {
  transition: 500
  curve: ease-in-out
  x: 8
  y: 8
  width: $width - 16 - $show-settings * max(270, $width / 4)
  height: $height - 16
}

settings-dimensions: {
  transition: 500
  curve: ease-in-out
  x: $width - $show-settings * max(270, $width / 4)
  y: 8
  width: $show-settings * max(270, $width / 4)
  height: $height - 16
}

// ------------------------------------------------

file: file-view.json
settings: settings.json

// ------------------------------------------------
