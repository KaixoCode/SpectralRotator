
// ------------------------------------------------

theme-name: Default

// ------------------------------------------------

variables: {
  $transition: 100
  $main-font: {
    map: map.png
    description: map.json
  }
}

// ------------------------------------------------

font: $main-font

background: {
  background-color: [15]
}

// ------------------------------------------------

file: {
  $instruction-button: {
    image: $icon
    background-color: {
      transition: $transition
      value: [255, 0]
      hovering: [255, 10]
    }
  }

  rotate-90: {
    $icon: rotate-90.png
    extends: $instruction-button
  }

  rotate-270: {
    $icon: rotate-270.png
    extends: $instruction-button
  }

  flip-horizontal: {
    $icon: reverse.png
    extends: $instruction-button
  }

  flip-vertical: {
    $icon: flip.png
    extends: $instruction-button
  }

  spectral-display: {
    color1: [0, 0, 0]
    color2: [60, 60, 179]
    color3: [239, 15, 0]
    color4: [255, 255, 64]
    color5: [255, 255, 255]
  }

  waveform-display: {
    stroke: [255]
  }

  selection: {
    start: {
      layers: {
        line: {
          rect: {
            dimensions: [0, 0, 1, "$height"]
            align: top-center
            fill: [255]
          }
        }
      }
    }
    
    end: {
      layers: {
        line: {
          rect: {
            dimensions: [0, 0, 1, "$height"]
            align: top-center
            fill: [255]
          }
        }
      }
    }
  }

  scrollbar: {
    handle: {
      background-color: [255, 255, 255, 40]
    }
  }
}

settings: {
  $setting: {
    layers: {
      value: {
        font: $main-font
        text-color: [255]
        text-align: top-left
        text-position: [4, 4]
        text: $value
      }
    }
  }

  fft-size: $setting
  fft-resolution: $setting
  fft-block-size: $setting
  fft-range: $setting
}

// ------------------------------------------------
